---
import Base from '../../layouts/Base.astro';
---
<Base title="Deputy Integrations — DH7" description="Custom integrations for Deputy. Connect your workforce management system to payroll, HR, and communication tools in real time.">

  <div class="max-w-lg">
    <p class="font-[family-name:var(--font-sans)] text-xs font-500 uppercase tracking-widest text-[#7A7068] mb-4">
      <a href="/integrations" class="hover:text-[#2A2520] transition-colors no-underline">Integrations</a> / Deputy
    </p>
    <h1 class="font-[family-name:var(--font-sans)] text-3xl font-600 tracking-tight text-[#2A2520] mb-6">Deputy Integrations</h1>
    <p class="text-lg leading-relaxed text-[#2A2520]">
      Deputy manages scheduling, timesheets, and attendance. But that data doesn't stay in Deputy — it needs to flow to payroll, accounting, HR, and the tools your team already uses day to day.
    </p>
    <p class="mt-4 leading-relaxed">We build integrations that connect Deputy to the rest of your business.</p>
  </div>

  <div class="mt-16 space-y-12">

    {[
      {
        title: 'Timesheets and payroll',
        body: "Approved timesheets in Deputy can flow automatically to your payroll or accounting system — Xero, QuickBooks, or others. No manual export, no copy-paste, no reconciliation at the end of the week. Hours worked are where they need to be as soon as they're approved.",
      },
      {
        title: 'Scheduling and calendars',
        body: "When shifts are published or updated in Deputy, the people affected should know immediately. We can push schedule changes to shared calendars, trigger notifications in Slack or Teams, or sync rosters to other planning tools — so your team isn't checking Deputy to find out when they're working.",
      },
      {
        title: 'Employees and onboarding',
        body: "When a new employee is added to Deputy, their details can flow automatically to your HR system, payroll platform, or onboarding tools. When someone leaves, that change can propagate too. One update in one place, reflected everywhere it needs to be.",
      },
      {
        title: 'Real-time',
        body: "Deputy's webhook API pushes updates the moment something changes — a timesheet submitted, a shift updated, a new starter added. No polling, no lag. Your downstream systems are updated in seconds.",
      },
    ].map(({ title, body }) => (
      <div class="border-t border-[#E6DFD0] pt-10">
        <h2 class="font-[family-name:var(--font-sans)] font-600 text-lg text-[#2A2520] mb-3">{title}</h2>
        <p class="leading-relaxed text-[#2A2520]">{body}</p>
      </div>
    ))}

    <div class="border-t border-[#E6DFD0] pt-10">
      <h2 class="font-[family-name:var(--font-sans)] font-600 text-lg text-[#2A2520] mb-3">✉️ Contact</h2>
      <p class="leading-relaxed text-[#2A2520]">Tell us your current stack and where the friction is. We'll scope what's possible and build it.</p>
      <a href="/contact" class="font-[family-name:var(--font-sans)] inline-block mt-4 text-[#A87820] hover:underline no-underline">✉️ Contact →</a>
    </div>

  </div>

</Base>
