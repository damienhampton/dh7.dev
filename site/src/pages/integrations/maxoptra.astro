---
import Base from '../../layouts/Base.astro';
---
<Base title="Maxoptra Integrations — DH7" description="Custom integrations for Maxoptra. Connect your route planning and delivery management to the rest of your operations.">

  <div class="max-w-lg">
    <p class="font-[family-name:var(--font-sans)] text-xs font-500 uppercase tracking-widest text-[#7A7068] mb-4">
      <a href="/integrations" class="hover:text-[#2A2520] transition-colors no-underline">Integrations</a> / Maxoptra
    </p>
    <h1 class="font-[family-name:var(--font-sans)] text-3xl font-600 tracking-tight text-[#2A2520] mb-6">Maxoptra Integrations</h1>
    <p class="text-lg leading-relaxed text-[#2A2520]">
      Maxoptra handles route planning and delivery management. But the data it needs — orders, contacts, job status — often lives somewhere else. And the data it produces — ETAs, completions, exceptions — needs to get back to those systems.
    </p>
    <p class="mt-4 leading-relaxed">We close that loop.</p>
  </div>

  <div class="mt-16 space-y-12">

    {[
      {
        title: 'Order and job import',
        body: "Push orders into Maxoptra automatically from your order management system, CRM, or rental platform. No manual re-entry, no lag between order creation and route planning.",
      },
      {
        title: 'Status and completion sync',
        body: "When a delivery is completed or an exception is raised in Maxoptra, downstream systems need to know. We can sync job status back to your CRM, trigger customer notifications, or update your operations dashboard in real time.",
      },
      {
        title: 'ETA and tracking data',
        body: "Maxoptra generates real-time ETA and location data. We can surface that where it's needed — in a customer-facing portal, in a support tool, or in a shared ops view — without anyone manually checking the Maxoptra console.",
      },
      {
        title: 'Real-time',
        body: "Route and delivery data changes fast. We build event-driven integrations so your systems reflect what's happening now, not what happened an hour ago.",
      },
    ].map(({ title, body }) => (
      <div class="border-t border-[#E6DFD0] pt-10">
        <h2 class="font-[family-name:var(--font-sans)] font-600 text-lg text-[#2A2520] mb-3">{title}</h2>
        <p class="leading-relaxed text-[#2A2520]">{body}</p>
      </div>
    ))}

    <div class="border-t border-[#E6DFD0] pt-10">
      <h2 class="font-[family-name:var(--font-sans)] font-600 text-lg text-[#2A2520] mb-3">✉️ Contact</h2>
      <p class="leading-relaxed text-[#2A2520]">Tell us what systems you're running and where the friction is. We'll scope the work and build it.</p>
      <a href="/contact" class="font-[family-name:var(--font-sans)] inline-block mt-4 text-[#A87820] hover:underline no-underline">✉️ Contact →</a>
    </div>

  </div>

</Base>
