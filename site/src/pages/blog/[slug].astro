---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(p => !p.data.draft)
    .map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} — Damien Hampton`} description={post.data.brief}>

  <article>
    <header class="mb-10">
      <h1 class="font-[family-name:var(--font-sans)] text-3xl font-600 tracking-tight text-[#2A2520] leading-tight mb-3">
        {post.data.title}
      </h1>
      <time datetime={post.data.publishedAt.toISOString()} class="font-[family-name:var(--font-sans)] text-sm text-[#7A7068]">
        {post.data.publishedAt.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>

    <div class="prose prose-stone max-w-none
      prose-headings:font-[family-name:var(--font-sans)]
      prose-a:text-[#A87820]
      prose-a:no-underline
      hover:prose-a:underline
      prose-code:text-[#2A2520]
      prose-pre:bg-[#F0EDE4]
      prose-pre:text-[#2A2520]">
      <Content />
    </div>
  </article>

  <div class="mt-16 pt-8 border-t border-[#E6DFD0]">
    <a href="/blog" class="font-[family-name:var(--font-sans)] text-sm text-[#A87820] hover:underline">← All posts</a>
  </div>

</Base>
