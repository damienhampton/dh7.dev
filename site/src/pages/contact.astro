---
import Base from '../layouts/Base.astro';
---
<Base title="Contact — DH7" description="Get in touch with Damien Hampton about custom integrations or anything else.">

  <div class="max-w-lg">
    <h1 class="font-[family-name:var(--font-sans)] text-3xl font-600 tracking-tight text-[#1C1C1A] mb-4">Get in touch</h1>
    <p class="leading-relaxed text-[#71717A] mb-10">
      Whether it's a question about custom integrations, a specific system you're working with, or something you read — feel free to reach out.
    </p>

    <form action="https://formspree.io/f/mdovyqog" method="POST" class="space-y-6">
      <input type="hidden" name="_next" value="https://dh7.dev/thanks" />

      <div>
        <label for="name" class="font-[family-name:var(--font-sans)] text-sm font-500 text-[#1C1C1A] block mb-2">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-3 border border-[#E4E4E0] rounded-none bg-white text-[#1C1C1A] font-[family-name:var(--font-sans)] text-sm focus:outline-none focus:border-[#1E3A5F] transition-colors"
        />
      </div>

      <div>
        <label for="email" class="font-[family-name:var(--font-sans)] text-sm font-500 text-[#1C1C1A] block mb-2">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-3 border border-[#E4E4E0] rounded-none bg-white text-[#1C1C1A] font-[family-name:var(--font-sans)] text-sm focus:outline-none focus:border-[#1E3A5F] transition-colors"
        />
      </div>

      <div>
        <label for="message" class="font-[family-name:var(--font-sans)] text-sm font-500 text-[#1C1C1A] block mb-2">Message</label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          class="w-full px-4 py-3 border border-[#E4E4E0] rounded-none bg-white text-[#1C1C1A] font-[family-name:var(--font-sans)] text-sm focus:outline-none focus:border-[#1E3A5F] transition-colors resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="font-[family-name:var(--font-sans)] text-sm font-500 bg-[#1C1C1A] text-[#FAFAF9] px-6 py-3 hover:bg-[#1E3A5F] transition-colors cursor-pointer border-0"
      >
        Send message
      </button>
    </form>
  </div>

</Base>
